generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  FINANCE
  VIEWER
}

enum WalletType {
  TREASURY
  AGENT
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  industry  String   @default("")
  timezone  String   @default("America/Los_Angeles (UTC-8)")
  currency  String   @default("USDC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  wallets         Wallet[]
  agents          Agent[]
  apiKeys         ApiKeyRecord[]
  paymentPolicies PaymentPolicy[]
  auditLogs       AuditLog[]
  tasks           Task[]
  transactions    Transaction[]
  settings        Setting[]
  approvals       Approval[]
  reports         Report[]
  vendors         Vendor[]
  subscriptions   Subscription[]
  apiServices     ApiService[]
  apiUsages       ApiUsage[]
  budgetRules     BudgetRule[]
  notifications   Notification[]
  executionLogs   ExecutionLog[]
  kpiSnapshots    KpiSnapshot[]
  aiProviders     AiProvider[]
}

// --- Auth Models (NextAuth.js + custom) ---

model User {
  id            String    @id @default(cuid())
  orgId         String?
  name          String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole  @default(VIEWER)
  locked        Boolean   @default(false)
  lockedAt      DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  org                Organization?       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accounts           Account[]
  sessions           Session[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordResetToken[]
  auditLogs          AuditLog[]

  @@index([orgId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  device       String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

// --- Business Models ---

model Wallet {
  id                  String     @id @default(cuid())
  orgId               String
  label               String
  address             String
  type                WalletType
  chain               String     @default("Arc Testnet")
  network             String     @default("eip155:5042002")
  encryptedPrivateKey String?
  status              String     @default("active")
  isDefault           Boolean    @default(false)
  deletedAt           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agents       Agent[]
  transactions Transaction[] @relation("WalletTransactions")
  outgoingTransfers Transaction[] @relation("FromWalletTransactions")
  incomingTransfers Transaction[] @relation("ToWalletTransactions")

  @@index([orgId])
}

model Agent {
  id             String    @id @default(cuid())
  orgId          String
  walletId       String?
  name           String
  type           String
  status         String    @default("active")
  description    String    @default("")
  version        String    @default("1.0.0")
  healthScore    Float     @default(100)
  memory         Json      @default("{}")
  lastActivityAt DateTime?
  lastError      String?
  config         Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  org     Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  wallet  Wallet?       @relation(fields: [walletId], references: [id])
  tasks   Task[]
  metrics AgentMetric[]

  @@index([orgId])
}

model AgentMetric {
  id            String   @id @default(cuid())
  agentId       String
  orgId         String
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  totalDuration Int      @default(0)
  taskCount     Int      @default(0)
  retryCount    Int      @default(0)
  period        String
  periodStart   DateTime
  createdAt     DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, periodStart])
  @@unique([agentId, period, periodStart])
}

model ApiKeyRecord {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  keyHash     String
  prefix      String
  permissions String[] @default([])
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model PaymentPolicy {
  id                    String  @id @default(cuid())
  orgId                 String  @unique
  autoApproveThreshold  Float   @default(500)
  dailyLimit            Float   @default(10)
  agentLimit            Float   @default(1000)
  require2fa            Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id @default(cuid())
  orgId     String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@index([orgId])
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  userId    String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt])
  @@index([entity, entityId])
}

model Task {
  id              String     @id @default(cuid())
  orgId           String
  agentId         String?
  agentName       String     @default("HeliOS")
  command         String
  commandType     String     @default("general")
  status          TaskStatus @default(PENDING)
  priority        String     @default("normal")
  progress        Int        @default(0)
  retryCount      Int        @default(0)
  correlationId   String?
  steps           Json       @default("[]")
  result          Json?
  logs            Json       @default("[]")
  cost            Float      @default(0)
  executionTimeMs Int?
  createdAt       DateTime   @default(now())
  completedAt     DateTime?

  org            Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agent          Agent?         @relation(fields: [agentId], references: [id])
  executionLogs  ExecutionLog[]

  @@index([orgId, createdAt])
  @@index([status])
  @@index([correlationId])
}

model Transaction {
  id           String            @id @default(cuid())
  orgId        String
  walletId     String?
  type         String
  amount       Float
  currency     String            @default("USDC")
  status       TransactionStatus @default(PENDING)
  reference    String?
  txHash       String?
  fromWalletId String?
  toWalletId   String?
  metadata     Json              @default("{}")
  createdAt    DateTime          @default(now())

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  wallet     Wallet?      @relation("WalletTransactions", fields: [walletId], references: [id])
  fromWallet Wallet?      @relation("FromWalletTransactions", fields: [fromWalletId], references: [id])
  toWallet   Wallet?      @relation("ToWalletTransactions", fields: [toWalletId], references: [id])

  @@index([orgId, createdAt])
  @@index([walletId])
  @@index([fromWalletId])
  @@index([toWalletId])
}

model Approval {
  id               String    @id @default(cuid())
  orgId            String
  requesterId      String?
  amount           Float
  vendor           String
  reason           String
  status           String    @default("pending")
  aiRecommendation String    @default("review")
  confidence       Float     @default(0.5)
  department       String    @default("General")
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
  resolvedBy       String?

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([status])
}

model Report {
  id        String   @id @default(cuid())
  orgId     String
  type      String
  name      String
  status    String   @default("generating")
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}

// --- API Cost Management ---

model Vendor {
  id           String   @id @default(cuid())
  orgId        String
  name         String
  category     String   @default("API")
  website      String?
  contactEmail String?
  logo         String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  apiServices   ApiService[]

  @@index([orgId])
}

model Subscription {
  id              String    @id @default(cuid())
  orgId           String
  vendorId        String?
  name            String
  plan            String    @default("free")
  monthlyRate     Float     @default(0)
  billingCycle    String    @default("monthly")
  status          String    @default("active")
  nextBillingDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([orgId])
}

model ApiService {
  id              String   @id @default(cuid())
  orgId           String
  vendorId        String?
  name            String
  provider        String
  apiKeyEncrypted String?
  dailyBudget     Float    @default(0)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor   Vendor?      @relation(fields: [vendorId], references: [id])
  usages   ApiUsage[]

  @@index([orgId])
}

model ApiUsage {
  id        String   @id @default(cuid())
  serviceId String
  orgId     String
  date      DateTime
  requests  Int      @default(0)
  tokens    Int      @default(0)
  cost      Float    @default(0)
  model     String?
  createdAt DateTime @default(now())

  service ApiService   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([serviceId, date])
  @@index([orgId, date])
}

model BudgetRule {
  id             String   @id @default(cuid())
  orgId          String
  name           String
  type           String   @default("monthly")
  limit          Float
  alertThreshold Float    @default(80)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Notification {
  id        String   @id @default(cuid())
  orgId     String
  userId    String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, userId, read])
  @@index([createdAt])
}

model ExecutionLog {
  id            String   @id @default(cuid())
  orgId         String
  taskId        String?
  agentId       String?
  severity      String   @default("info")
  component     String
  action        String
  detail        String
  correlationId String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  task Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([taskId])
  @@index([correlationId])
}

model KpiSnapshot {
  id                   String   @id @default(cuid())
  orgId                String
  period               String
  periodStart          DateTime
  totalPayments        Int      @default(0)
  totalVolume          Float    @default(0)
  avgTransactionSize   Float    @default(0)
  budgetEfficiency     Float    @default(0)
  costPerTask          Float    @default(0)
  taskSuccessRate      Float    @default(0)
  totalAgentExecutions Int      @default(0)
  estimatedSavings     Float    @default(0)
  activeAgents         Int      @default(0)
  avgExecutionTime     Float    @default(0)
  totalApiCost         Float    @default(0)
  totalApiCalls        Int      @default(0)
  createdAt            DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, period, periodStart])
  @@index([orgId, periodStart])
}

model AiProvider {
  id              String   @id @default(cuid())
  orgId           String
  name            String
  slug            String
  baseUrl         String
  apiKeyEncrypted String?
  defaultModel    String
  status          String   @default("active")
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, slug])
  @@index([orgId])
}
